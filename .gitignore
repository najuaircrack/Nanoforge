```gitignore id="n8v2qx"
# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Virtual environments
.venv/
venv/
env/

# Build / packaging
build/
dist/
*.egg-info/
.eggs/

# IDEs
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# TensorBoard
runs/**/events.out.tfevents.*

# Training outputs
runs/
checkpoints/
outputs/

# Model weights
*.pt
*.pth
*.ckpt
*.bin
*.safetensors
*.onnx
*.gguf

# Large datasets
data/raw/
data/packed/
data/chat/

# Tokenizers
data/tokenizers/

# Reports
reports/

# Cache
.cache/
.pytest_cache/
.mypy_cache/

# Jupyter
.ipynb_checkpoints/

# HuggingFace
hf_cache/
huggingface/

# Temporary files
tmp/
temp/
*.tmp

# Metrics / dashboards
metrics.jsonl
nextupdate.txt
# WandB
wandb/

# CUDA
*.cu.o

# Export artifacts
exports/

# Generated text
samples/
generated/

# Environment variables
.env
.env.local
```
